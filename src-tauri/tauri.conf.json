{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw本地版",
  "version": "0.2.0",
  "identifier": "com.openclaw.local-installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenClaw 本地版安装器",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 700,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    },
    "shortDescription": "OpenClaw 本地版安装器",
    "longDescription": "零 API 费用、完全本地化、自动硬件检测与模型推荐的 OpenClaw 安装器",
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/your-repo/openclaw-local-installer/releases/latest/download/{{target}}-{{arch}}.json"
      ],
      "pubkey": ""
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Local Installer",
  "version": "1.5.1",
  "identifier": "com.openclaw.local-installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "OpenClaw Local Installer",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 700,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon-512.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "shortDescription": "OpenClaw Local Installer",
    "longDescription": "Zero API fees, fully local, automatic hardware detection and model recommendation for OpenClaw",
    "category": "DeveloperTool"
  }
}
